vocab = dict(zip(df_vocab.palavra, df_vocab.id))

frase = "o banco bloqueou o cartao"
tokens = [vocab[p] for p in frase.split()]

d_model = 64
n_camadas = 6

np.random.seed(42)
emb_table = np.random.randn(len(vocab), d_model)


X = emb_table[tokens]
X = X[np.newaxis, :]  
