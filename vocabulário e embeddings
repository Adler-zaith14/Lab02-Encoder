import numpy as np
import pandas as pd

palavras = ["o", "banco", "bloqueou", "cartao"]
ids      = [0,   1,       2,          3      ]
df_vocab = pd.DataFrame({"palavra": palavras, "id": ids})
vocab    = dict(zip(df_vocab.palavra, df_vocab.id))

frase  = "o banco bloqueou o cartao"
tokens = [vocab[p] for p in frase.split()]

print(df_vocab)
print(f"\nTokens: {tokens}")
