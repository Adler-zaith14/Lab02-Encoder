def self_attention(x, d_model, n_heads=8):
    dk = d_model // n_heads

   
    Wq = np.random.randn(d_model, d_model)
    Wk = np.random.randn(d_model, d_model)
    Wv = np.random.randn(d_model, d_model)

    Q = x @ Wq
    K = x @ Wk
    V = x @ Wv

    scores = Q @ K.transpose(0, 2, 1)
    scores = scores / np.sqrt(dk)
    attn = softmax(scores)

    return attn @ V
